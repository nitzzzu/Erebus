# ─── Erebus — Environment Variables ──────────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# Only EREBUS_OPENAI_API_KEY (or another provider key) is required.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider Keys (at least one required) ────────────────────────────────
# EREBUS_OPENAI_API_KEY=sk-...
# EREBUS_ANTHROPIC_API_KEY=sk-ant-...
# EREBUS_GOOGLE_API_KEY=...
# EREBUS_OPENROUTER_API_KEY=...

# ── Model Configuration ──────────────────────────────────────────────────────
# EREBUS_DEFAULT_MODEL=openai:gpt-4o
# EREBUS_REASONING_MODEL=anthropic:claude-sonnet-4-20250514

# ── Telegram Bot (optional) ──────────────────────────────────────────────────
# EREBUS_TELEGRAM_TOKEN=123456:ABC-DEF...
# EREBUS_TELEGRAM_WEBHOOK_URL=https://your-domain.com

# ── Microsoft Teams Bot (optional) ───────────────────────────────────────────
# EREBUS_TEAMS_APP_ID=...
# EREBUS_TEAMS_APP_PASSWORD=...

# ── Authentication (optional) ────────────────────────────────────────────────
# EREBUS_AUTH_ENABLED=false
# EREBUS_AUTH_PROVIDER=github            # "github" or "authelia"
#
# GitHub OAuth (required when EREBUS_AUTH_PROVIDER=github)
# EREBUS_GITHUB_CLIENT_ID=<your-github-oauth-app-client-id>
# EREBUS_GITHUB_CLIENT_SECRET=<your-github-oauth-app-client-secret>
# EREBUS_GITHUB_ALLOWED_LOGINS=user1,user2   # optional allowlist
#
# Shared secret for signing session cookies (generate: openssl rand -hex 32)
# EREBUS_SECRET_KEY=<random-32-byte-hex>
#
# Authelia (required when EREBUS_AUTH_PROVIDER=authelia)
# Place Erebus behind an Authelia forward-auth proxy.
# Authelia injects these headers after successful authentication:
# EREBUS_AUTHELIA_HEADER_USER=Remote-User
# EREBUS_AUTHELIA_HEADER_NAME=Remote-Name

# ── Notifications (apprise) ──────────────────────────────────────────────────
# Set a single default notification URL using apprise URL syntax.
# Example: tgram://bottoken/chatid  or  mailto://user:pass@gmail.com
# For multiple channels, use the Notifications UI at /notifications.
# EREBUS_APPRISE_DEFAULT_URL=

# ── Gateway / API Server ─────────────────────────────────────────────────────
# EREBUS_API_HOST=0.0.0.0
# EREBUS_API_PORT=8741

# ── Obsidian Local REST API ───────────────────────────────────────────────────
# Install plugin: https://github.com/coddingtonbear/obsidian-local-rest-api
# EREBUS_OBSIDIAN_API_URL=https://localhost:27124
# EREBUS_OBSIDIAN_API_KEY=your-api-key

# ── Agentic Fetch API ─────────────────────────────────────────────────────────
# Used for web search and web page fetching instead of DuckDuckGo.
# https://github.com/nitzzzu/agentic-fetch
# EREBUS_AGENTIC_FETCH_URL=http://localhost:3001
